{% extends 'base.html.twig' %}

{% block title %}Chat - Myo{% endblock %}

{% block stylesheets %}
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #1a1a2e; color: #e0e0e0; height: 100vh; display: flex; flex-direction: column; }
    .header { padding: 16px 24px; background: #16213e; border-bottom: 1px solid #0f3460; display: flex; align-items: center; gap: 12px; }
    .header h1 { font-size: 18px; font-weight: 600; }
    .header .model { font-size: 12px; color: #7b8794; background: #0f3460; padding: 4px 10px; border-radius: 12px; }
    .messages { flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px; }
    .message { max-width: 75%; padding: 12px 16px; border-radius: 12px; line-height: 1.5; white-space: pre-wrap; word-wrap: break-word; }
    .message.user { align-self: flex-end; background: #0f3460; color: #e0e0e0; border-bottom-right-radius: 4px; }
    .message.assistant { align-self: flex-start; background: #16213e; color: #e0e0e0; border-bottom-left-radius: 4px; border: 1px solid #0f3460; }
    .message .role { font-size: 11px; font-weight: 600; text-transform: uppercase; margin-bottom: 4px; color: #7b8794; }
    .input-area { padding: 16px 24px; background: #16213e; border-top: 1px solid #0f3460; }
    .input-form { display: flex; gap: 12px; max-width: 900px; margin: 0 auto; }
    .input-form textarea { flex: 1; padding: 12px 16px; border: 1px solid #0f3460; border-radius: 8px; background: #1a1a2e; color: #e0e0e0; font-size: 14px; font-family: inherit; resize: none; outline: none; min-height: 48px; max-height: 120px; }
    .input-form textarea:focus { border-color: #533483; }
    .input-form button { padding: 12px 24px; background: #533483; color: white; border: none; border-radius: 8px; font-size: 14px; cursor: pointer; font-weight: 500; white-space: nowrap; }
    .input-form button:hover { background: #6b44a0; }
    .input-form button:disabled { opacity: 0.5; cursor: not-allowed; }
    .typing { display: none; align-self: flex-start; padding: 12px 16px; background: #16213e; border: 1px solid #0f3460; border-radius: 12px; border-bottom-left-radius: 4px; }
    .typing.active { display: block; }
    .typing span { display: inline-block; width: 8px; height: 8px; background: #533483; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out; margin-right: 4px; }
    .typing span:nth-child(2) { animation-delay: 0.2s; }
    .typing span:nth-child(3) { animation-delay: 0.4s; margin-right: 0; }
    @keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
</style>
{% endblock %}

{% block body %}
<div class="header">
    <h1>Myo Chat</h1>
    <span class="model">claude-sonnet-4</span>
</div>

<div class="messages" id="messages"></div>

<div class="typing" id="typing"><span></span><span></span><span></span></div>

<div class="input-area">
    <form class="input-form" id="chatForm">
        <textarea id="userInput" placeholder="Envoyer un message..." rows="1"></textarea>
        <button type="submit" id="sendBtn">Envoyer</button>
    </form>
</div>
{% endblock %}

{% block javascripts %}
<script>
    const messagesEl = document.getElementById('messages');
    const form = document.getElementById('chatForm');
    const input = document.getElementById('userInput');
    const sendBtn = document.getElementById('sendBtn');
    const typingEl = document.getElementById('typing');

    const history = [];

    input.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });

    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            form.dispatchEvent(new Event('submit'));
        }
    });

    function addMessage(role, content) {
        const div = document.createElement('div');
        div.className = 'message ' + role;
        const roleLabel = document.createElement('div');
        roleLabel.className = 'role';
        roleLabel.textContent = role === 'user' ? 'Vous' : 'Assistant';
        div.appendChild(roleLabel);
        div.appendChild(document.createTextNode(content));
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const text = input.value.trim();
        if (!text) return;

        addMessage('user', text);
        history.push({ role: 'user', content: text });
        input.value = '';
        input.style.height = 'auto';
        sendBtn.disabled = true;
        typingEl.classList.add('active');

        try {
            const res = await fetch('{{ path("chat_api") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: history })
            });
            const data = await res.json();

            if (data.error) {
                addMessage('assistant', 'Erreur: ' + data.error);
            } else {
                addMessage('assistant', data.response);
                history.push({ role: 'assistant', content: data.response });
            }
        } catch (err) {
            addMessage('assistant', 'Erreur de connexion: ' + err.message);
        } finally {
            typingEl.classList.remove('active');
            sendBtn.disabled = false;
            input.focus();
        }
    });

    input.focus();
</script>
{% endblock %}
